                  "",
                  "const productResponse = pm.response.json();",
                  "",
                  "",
                  "const creationSchema = {",
                  "    \"type\": \"object\",",
                  "    \"required\": [\"id\", \"name\", \"price\", \"sku\", \"description\"],",
                  "    \"properties\": {",
                  "        \"id\": { \"type\": \"number\" },",
                  "        \"name\": { \"type\": \"string\" },",
                  "        \"price\": { \"type\": \"number\" },",
                  "        \"sku\": { \"type\": \"number\" },",
                  "        \"description\": { \"type\": \"string\" }",
                  "    }",
                  "};",
                  "",
                  "pm.test(\"JSON-structure is equal to responce\", function () {",
                  "    pm.response.to.have.jsonSchema(creationSchema);",
                  "});",
                  "",
                  "pm.test(\"Created product data is equal to sent data\", function () {",
                  "    pm.expect(productResponse.name).to.eql(\"apple\");",
                  "    pm.expect(productResponse.price).to.eql(3-);",
                  "});",
                  "",
                  "",
                  "if (productResponse.id) {",
